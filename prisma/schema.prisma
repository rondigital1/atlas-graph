generator client {
  provider     = "prisma-client"
  output       = "../packages/db/generated/prisma"
  moduleFormat = "esm"
  runtime      = "nodejs"
  engineType   = "client"
}

datasource db {
  provider = "postgresql"
}

enum PlannerRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum ToolExecutionStatus {
  SUCCEEDED
  FAILED
  PARTIAL
}

enum TravelPlanStatus {
  DRAFT
  GENERATING
  DONE
  ERROR
}

model PlannerRun {
  id                  String           @id @default(uuid()) @db.Uuid
  status              PlannerRunStatus @default(PENDING)
  requestId           String?          @unique
  destination         String?
  startDate           DateTime?
  endDate             DateTime?
  budget              String?
  travelStyle         String?
  groupType           String?
  modelName           String?
  promptVersion       String?
  orchestratorVersion String?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  input               PlannerRunInput?
  toolResults         PlannerRunToolResult[]
  output              PlannerRunOutput?
  errors              PlannerRunError[]

  @@index([status])
  @@index([destination])
  @@index([createdAt])
  @@index([promptVersion])
}

model PlannerRunInput {
  id           String     @id @default(uuid()) @db.Uuid
  plannerRunId String     @unique @db.Uuid
  payload      Json
  createdAt    DateTime   @default(now())
  plannerRun   PlannerRun @relation(fields: [plannerRunId], references: [id], onDelete: Cascade)
}

model PlannerRunToolResult {
  id           String              @id @default(uuid()) @db.Uuid
  plannerRunId String              @db.Uuid
  toolName     String
  toolCategory String?
  sequence     Int
  status       ToolExecutionStatus @default(SUCCEEDED)
  provider     String?
  latencyMs    Int?
  payload      Json
  createdAt    DateTime            @default(now())
  plannerRun   PlannerRun          @relation(fields: [plannerRunId], references: [id], onDelete: Cascade)

  @@index([plannerRunId])
  @@index([toolName])
  @@index([toolCategory])
  @@index([sequence])
}

model PlannerRunOutput {
  id           String     @id @default(uuid()) @db.Uuid
  plannerRunId String     @unique @db.Uuid
  outputFormat String?
  payload      Json
  createdAt    DateTime   @default(now())
  plannerRun   PlannerRun @relation(fields: [plannerRunId], references: [id], onDelete: Cascade)
}

model PlannerRunError {
  id           String     @id @default(uuid()) @db.Uuid
  plannerRunId String     @db.Uuid
  errorType    String?
  stepName     String?
  message      String     @db.Text
  details      Json?
  createdAt    DateTime   @default(now())
  plannerRun   PlannerRun @relation(fields: [plannerRunId], references: [id], onDelete: Cascade)

  @@index([plannerRunId])
  @@index([errorType])
  @@index([stepName])
}

model TravelPlan {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String
  status    TravelPlanStatus @default(DRAFT)
  input     Json
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([updatedAt(sort: Desc)])
  @@index([userId, updatedAt(sort: Desc)])
  @@map("travel_plans")
}
