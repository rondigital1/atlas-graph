generator client {
  provider     = "prisma-client"
  output       = "../packages/db/generated/prisma"
  moduleFormat = "esm"
  runtime      = "nodejs"
  engineType   = "client"
}

datasource db {
  provider = "postgresql"
}

enum PlannerRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum ToolExecutionStatus {
  SUCCEEDED
  FAILED
  PARTIAL
}

enum TravelPlanStatus {
  DRAFT
  GENERATING
  DONE
  ERROR
}

enum GenerationRunStatus {
  pending
  running
  done
  error
}

model PlannerRun {
  id                  String           @id @default(uuid()) @db.Uuid
  status              PlannerRunStatus @default(PENDING)
  requestId           String?          @unique
  destination         String?
  startDate           DateTime?
  endDate             DateTime?
  budget              String?
  travelStyle         String?
  groupType           String?
  modelName           String?
  promptVersion       String?
  orchestratorVersion String?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  input               PlannerRunInput?
  toolResults         PlannerRunToolResult[]
  output              PlannerRunOutput?
  errors              PlannerRunError[]

  @@index([status])
  @@index([destination])
  @@index([createdAt])
  @@index([promptVersion])
}

model PlannerRunInput {
  id           String     @id @default(uuid()) @db.Uuid
  plannerRunId String     @unique @db.Uuid
  payload      Json
  createdAt    DateTime   @default(now())
  plannerRun   PlannerRun @relation(fields: [plannerRunId], references: [id], onDelete: Cascade)
}

model PlannerRunToolResult {
  id           String              @id @default(uuid()) @db.Uuid
  plannerRunId String              @db.Uuid
  toolName     String
  toolCategory String?
  sequence     Int
  status       ToolExecutionStatus @default(SUCCEEDED)
  provider     String?
  latencyMs    Int?
  payload      Json
  createdAt    DateTime            @default(now())
  plannerRun   PlannerRun          @relation(fields: [plannerRunId], references: [id], onDelete: Cascade)

  @@index([plannerRunId])
  @@index([toolName])
  @@index([toolCategory])
  @@index([sequence])
}

model PlannerRunOutput {
  id           String     @id @default(uuid()) @db.Uuid
  plannerRunId String     @unique @db.Uuid
  outputFormat String?
  payload      Json
  createdAt    DateTime   @default(now())
  plannerRun   PlannerRun @relation(fields: [plannerRunId], references: [id], onDelete: Cascade)
}

model PlannerRunError {
  id           String     @id @default(uuid()) @db.Uuid
  plannerRunId String     @db.Uuid
  errorType    String?
  stepName     String?
  message      String     @db.Text
  details      Json?
  createdAt    DateTime   @default(now())
  plannerRun   PlannerRun @relation(fields: [plannerRunId], references: [id], onDelete: Cascade)

  @@index([plannerRunId])
  @@index([errorType])
  @@index([stepName])
}

model TravelPlan {
  id                String             @id @default(uuid()) @db.Uuid
  userId            String
  status            TravelPlanStatus   @default(DRAFT)
  input             Json
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  itineraryVersions ItineraryVersion[]
  generationRuns    GenerationRun[]

  @@index([updatedAt(sort: Desc)])
  @@index([userId, updatedAt(sort: Desc)])
  @@map("travel_plans")
}

model ItineraryVersion {
  id              String        @id @default(uuid()) @db.Uuid
  travelPlanId    String        @db.Uuid
  versionNumber   Int
  content         Json
  generatedAt     DateTime      @default(now())
  generationRunId String        @unique @db.Uuid
  isCurrent       Boolean       @default(false)
  travelPlan      TravelPlan    @relation(fields: [travelPlanId], references: [id], onDelete: Cascade)
  generationRun   GenerationRun @relation(fields: [generationRunId], references: [id], onDelete: Cascade)

  @@unique([travelPlanId, versionNumber])
  @@index([travelPlanId, generatedAt(sort: Desc)])
  @@map("itinerary_versions")
}

model GenerationRun {
  id               String              @id @default(uuid()) @db.Uuid
  travelPlanId     String              @db.Uuid
  status           GenerationRunStatus @default(pending)
  inputSnapshot    Json
  providerData     Json?
  modelProvider    String?
  modelName        String?
  modelVersion     String?
  durationMs       Int                 @default(0)
  errorMessage     String?             @db.Text
  errorPayload     Json?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  travelPlan       TravelPlan          @relation(fields: [travelPlanId], references: [id], onDelete: Cascade)
  itineraryVersion ItineraryVersion?

  @@index([travelPlanId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("generation_runs")
}
