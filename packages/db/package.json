{
  "name": "@atlas-graph/db",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client/index.ts",
    "./health": "./src/health.ts",
    "./repositories": "./src/repositories/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:check": "tsx src/scripts/check-database.ts",
    "prisma:generate": "prisma generate --config ../../prisma.config.ts",
    "prisma:validate": "prisma validate --config ../../prisma.config.ts",
    "prisma:migrate:dev": "prisma migrate dev --config ../../prisma.config.ts",
    "prisma:migrate:deploy": "prisma migrate deploy --config ../../prisma.config.ts",
    "prisma:migrate:status": "prisma migrate status --config ../../prisma.config.ts",
    "prisma:studio": "prisma studio --config ../../prisma.config.ts"
  },
  "dependencies": {
    "@atlas-graph/core": "workspace:*",
    "@atlas-graph/config": "workspace:*",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
